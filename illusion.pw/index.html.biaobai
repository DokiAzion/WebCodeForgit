<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>致 李欣妍</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            min-height: 100vh;
            background: #06050a;
            font-family: 'Noto Serif SC', 'STSong', 'Songti SC', 'Georgia', serif;
            overflow-x: hidden;
            cursor: default;
            user-select: none;
            scroll-behavior: smooth;
        }

        /* ═══ Canvas: nebula + fireflies ═══ */
        canvas#bg {
            position: fixed;
            top: 0; left: 0;
            width: 100%; height: 100%;
            z-index: 0;
            pointer-events: none;
        }

        /* ═══ Scrollable wrapper ═══ */
        .scroll-stage {
            position: relative;
            z-index: 1;
        }

        /* ═══ Hero section — full viewport ═══ */
        .hero {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            padding: 40px 24px;
            position: relative;
        }

        /* Heartbeat ring */
        .heart-ring {
            width: 140px; height: 140px;
            border-radius: 50%;
            border: 1px solid rgba(220,180,140,0.25);
            display: flex;
            align-items: center;
            justify-content: center;
            animation: ringBeat 1.8s ease-in-out infinite;
            margin-bottom: 10px;
            position: relative;
        }
        .heart-ring::before {
            content: '';
            position: absolute;
            inset: -12px;
            border-radius: 50%;
            border: 1px solid rgba(220,180,140,0.1);
            animation: ringBeat 1.8s ease-in-out 0.3s infinite;
        }

        @keyframes ringBeat {
            0%, 100% { transform: scale(1); border-color: rgba(220,180,140,0.25); }
            14%      { transform: scale(1.08); border-color: rgba(220,180,140,0.5); }
            28%      { transform: scale(1); border-color: rgba(220,180,140,0.25); }
            42%      { transform: scale(1.04); border-color: rgba(220,180,140,0.35); }
            56%      { transform: scale(1); border-color: rgba(220,180,140,0.25); }
        }

        .heart-core {
            font-size: 52px;
            animation: coreBeat 1.8s ease-in-out infinite;
            filter: drop-shadow(0 0 20px rgba(255,120,140,0.6));
        }
        @keyframes coreBeat {
            0%, 100% { transform: scale(1); }
            14%      { transform: scale(1.25); }
            28%      { transform: scale(1); }
            42%      { transform: scale(1.12); }
            56%      { transform: scale(1); }
        }

        /* Name */
        .name-hero {
            font-size: clamp(2.4rem, 6vw, 3.6rem);
            font-weight: 700;
            letter-spacing: 12px;
            color: #e4c68b;
            text-shadow: 0 0 80px rgba(228,198,139,0.4), 0 0 160px rgba(210,160,100,0.2);
            margin: 24px 0 8px;
            animation: nameIn 2s cubic-bezier(0.22,0.61,0.36,1) forwards;
            opacity: 0;
            transform: translateY(30px);
        }
        @keyframes nameIn {
            to { opacity: 1; transform: translateY(0); }
        }

        .for-you {
            color: rgba(200,180,155,0.5);
            font-size: 0.9rem;
            letter-spacing: 8px;
            margin-bottom: 32px;
            animation: nameIn 2s 0.3s cubic-bezier(0.22,0.61,0.36,1) forwards;
            opacity: 0;
            transform: translateY(20px);
        }

        /* Scroll prompt */
        .scroll-prompt {
            position: absolute;
            bottom: 40px;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 8px;
            color: rgba(200,180,155,0.35);
            font-size: 0.75rem;
            letter-spacing: 4px;
            animation: promptFloat 3s ease-in-out infinite, nameIn 1.5s 1s cubic-bezier(0.22,0.61,0.36,1) forwards;
            opacity: 0;
        }
        .scroll-arrow {
            width: 20px; height: 20px;
            border-right: 1px solid rgba(200,180,155,0.4);
            border-bottom: 1px solid rgba(200,180,155,0.4);
            transform: rotate(45deg);
            animation: arrowBob 2s ease-in-out infinite;
        }
        @keyframes arrowBob {
            0%, 100% { transform: rotate(45deg) translateY(0); }
            50%      { transform: rotate(45deg) translateY(8px); }
        }
        @keyframes promptFloat {
            0%, 100% { transform: translateY(0); }
            50%      { transform: translateY(-6px); }
        }

        /* ═══ Sections ═══ */
        .section {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            padding: 60px 28px;
            position: relative;
        }

        .section-text {
            max-width: 520px;
            color: rgba(215,200,180,0.8);
            font-size: clamp(1rem, 2.5vw, 1.15rem);
            line-height: 2.5;
            letter-spacing: 3px;
            opacity: 0;
            transform: translateY(40px);
            transition: opacity 1.2s ease, transform 1.2s ease;
        }
        .section-text.visible {
            opacity: 1;
            transform: translateY(0);
        }

        .section-text .highlight {
            color: #e4c68b;
            font-weight: 600;
            text-shadow: 0 0 30px rgba(228,198,139,0.3);
        }

        .section-text .name-inline {
            font-size: 1.3em;
            font-weight: 700;
            color: #e4c68b;
            letter-spacing: 6px;
            text-shadow: 0 0 40px rgba(228,198,139,0.35);
            white-space: nowrap;
        }

        .thin-rule {
            width: 50px;
            height: 1px;
            background: linear-gradient(90deg, transparent, rgba(200,160,110,0.5), transparent);
            margin: 40px auto;
            opacity: 0;
            transform: scaleX(0);
            transition: opacity 1s ease 0.3s, transform 1s ease 0.3s;
        }
        .thin-rule.visible {
            opacity: 1;
            transform: scaleX(1);
        }

        /* ═══ Final section ═══ */
        .final {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            padding: 60px 28px;
        }

        .final-question {
            font-size: clamp(1.3rem, 3vw, 1.6rem);
            color: #e4c68b;
            letter-spacing: 6px;
            text-shadow: 0 0 50px rgba(228,198,139,0.4);
            opacity: 0;
            transform: translateY(30px);
            transition: opacity 1.5s ease, transform 1.5s ease;
            line-height: 2;
        }
        .final-question.visible {
            opacity: 1;
            transform: translateY(0);
        }

        .forever {
            margin-top: 48px;
            font-size: 0.85rem;
            color: rgba(180,160,140,0.4);
            letter-spacing: 6px;
            opacity: 0;
            transition: opacity 1.5s ease 0.5s;
        }
        .forever.visible { opacity: 1; }

        /* ═══ Click hearts ═══ */
        .burst {
            position: fixed;
            pointer-events: none;
            z-index: 100;
            font-size: 20px;
            animation: burstOut 0.9s ease-out forwards;
        }
        @keyframes burstOut {
            0%   { transform: translate(0,0) scale(0.2); opacity: 1; }
            100% { transform: translate(var(--bx), var(--by)) scale(1.5) rotate(var(--br)); opacity: 0; }
        }

        @media (max-width: 500px) {
            .section-text { line-height: 2.2; letter-spacing: 2px; }
            .name-hero { letter-spacing: 8px; }
            .heart-ring { width: 110px; height: 110px; }
            .heart-core { font-size: 40px; }
        }
    </style>
</head>
<body>

    <canvas id="bg"></canvas>

    <div class="scroll-stage">

        <!-- ═══ Hero ═══ -->
        <section class="hero">
            <div class="heart-ring">
                <span class="heart-core">&#10084;&#65039;</span>
            </div>
            <h1 class="name-hero">李欣妍</h1>
            <p class="for-you">&#10022; 写给你 &#10022;</p>

            <div class="scroll-prompt">
                <span>向下翻阅</span>
                <div class="scroll-arrow"></div>
            </div>
        </section>

        <!-- ═══ Section 1: First meeting ═══ -->
        <section class="section" data-reveal>
            <div class="thin-rule"></div>
            <p class="section-text" data-reveal>
                我常常在想，<br>
                人海茫茫，<br>
                为什么偏偏遇见了<span class="highlight">你</span>。
            </p>
        </section>

        <!-- ═══ Section 2: Feelings ═══ -->
        <section class="section" data-reveal>
            <div class="thin-rule"></div>
            <p class="section-text" data-reveal>
                后来我明白了。<br><br>
                因为有些人，<br>
                就是注定要出现在你生命里的。<br><br>
                像一场温柔的雨，<br>
                落在干涸了很久的土地上。
            </p>
        </section>

        <!-- ═══ Section 3: Her name ═══ -->
        <section class="section" data-reveal>
            <div class="thin-rule"></div>
            <p class="section-text" data-reveal>
                你知道吗，<br>
                <span class="name-inline">李欣妍</span><br>
                这三个字，<br>
                是我现在读过最美的诗。<br><br>
                光是念出你的名字，<br>
                心里就像被什么填满了。
            </p>
        </section>

        <!-- ═══ Section 4: What she brings ═══ -->
        <section class="section" data-reveal>
            <div class="thin-rule"></div>
            <p class="section-text" data-reveal>
                你笑起来的时候，<br>
                比我见过的所有日出都好看。<br><br>
                你说话的时候，<br>
                全世界都安静下来听。<br><br>
                你存在本身，<br>
                就已经让我觉得——<br>
                这个世界，真好啊。
            </p>
        </section>

        <!-- ═══ Section 5: The ask ═══ -->
        <section class="final" data-reveal>
            <div class="thin-rule"></div>
            <p class="final-question" data-reveal>
                李欣妍，<br>
                我想和你一起，<br>
                去看春天的花、<br>
                夏天的海、<br>
                秋天的月亮、<br>
                冬天的雪。<br><br>
                想和你一起，<br>
                把「我」变成「我们」。<br><br>
                <span style="font-size:1.3em; display:inline-block; margin-top:16px;">你愿意吗？</span>
            </p>
            <p class="forever" data-reveal>&#9829; 等你回答 &#9829;</p>
        </section>

    </div>

    <script>
        /* ═══════════════════════════════════════════
           CANVAS — Nebula + Fireflies
           ═══════════════════════════════════════════ */
        const canvas = document.getElementById('bg');
        const ctx = canvas.getContext('2d');

        let W, H;
        let mouse = { x: -500, y: -500 };
        let fireflies = [];

        function resize() {
            W = canvas.width = window.innerWidth;
            H = canvas.height = window.innerHeight;
        }
        window.addEventListener('resize', resize);
        resize();

        // Fireflies
        const FF_COUNT = 80;
        for (let i = 0; i < FF_COUNT; i++) {
            fireflies.push({
                x: Math.random() * W,
                y: Math.random() * H,
                vx: (Math.random() - 0.5) * 0.3,
                vy: (Math.random() - 0.5) * 0.3,
                r: Math.random() * 2 + 0.8,
                glow: Math.random() * 0.5 + 0.3,
                phase: Math.random() * Math.PI * 2,
                speed: Math.random() * 0.02 + 0.008,
            });
        }

        function draw(timestamp) {
            ctx.clearRect(0, 0, W, H);

            // ── Soft nebula blobs (very subtle) ──
            const blobs = [
                { x: W * 0.25, y: H * 0.3, r: W * 0.35, color: '180,120,200' },
                { x: W * 0.75, y: H * 0.6, r: W * 0.3,  color: '200,140,100' },
                { x: W * 0.5,  y: H * 0.8, r: W * 0.4,  color: '140,120,180' },
            ];
            for (const b of blobs) {
                const grad = ctx.createRadialGradient(b.x, b.y, 0, b.x, b.y, b.r);
                grad.addColorStop(0, `rgba(${b.color},0.025)`);
                grad.addColorStop(0.5, `rgba(${b.color},0.01)`);
                grad.addColorStop(1, 'rgba(0,0,0,0)');
                ctx.fillStyle = grad;
                ctx.fillRect(0, 0, W, H);
            }

            // ── Fireflies ──
            for (const ff of fireflies) {
                // Wander
                ff.vx += (Math.random() - 0.5) * 0.04;
                ff.vy += (Math.random() - 0.5) * 0.04;
                ff.vx *= 0.995;
                ff.vy *= 0.995;
                ff.x += ff.vx;
                ff.y += ff.vy;

                // Wrap
                if (ff.x < -20) ff.x = W + 20;
                if (ff.x > W + 20) ff.x = -20;
                if (ff.y < -20) ff.y = H + 20;
                if (ff.y > H + 20) ff.y = -20;

                // Gentle pull toward mouse (within range)
                const dx = mouse.x - ff.x;
                const dy = mouse.y - ff.y;
                const dist = Math.sqrt(dx * dx + dy * dy);
                if (dist < 200 && dist > 1) {
                    const force = (1 - dist / 200) * 0.03;
                    ff.vx += (dx / dist) * force;
                    ff.vy += (dy / dist) * force;
                }

                // Pulsing glow
                const pulse = ff.glow + Math.sin(timestamp * ff.speed + ff.phase) * 0.25;
                const alpha = Math.max(0.08, Math.min(1, pulse));

                // Draw glow
                const glowGrad = ctx.createRadialGradient(ff.x, ff.y, 0, ff.x, ff.y, ff.r * 6);
                glowGrad.addColorStop(0, `rgba(240,210,160,${alpha * 0.5})`);
                glowGrad.addColorStop(0.5, `rgba(240,190,130,${alpha * 0.08})`);
                glowGrad.addColorStop(1, 'rgba(0,0,0,0)');
                ctx.fillStyle = glowGrad;
                ctx.beginPath();
                ctx.arc(ff.x, ff.y, ff.r * 6, 0, Math.PI * 2);
                ctx.fill();

                // Core
                ctx.beginPath();
                ctx.arc(ff.x, ff.y, ff.r, 0, Math.PI * 2);
                ctx.fillStyle = `rgba(255,230,190,${alpha})`;
                ctx.fill();
            }

            requestAnimationFrame(draw);
        }
        requestAnimationFrame(draw);

        document.addEventListener('mousemove', e => {
            mouse.x = e.clientX;
            mouse.y = e.clientY;
        });
        document.addEventListener('touchmove', e => {
            mouse.x = e.touches[0].clientX;
            mouse.y = e.touches[0].clientY;
        }, { passive: true });

        /* ═══════════════════════════════════════════
           SCROLL REVEAL
           ═══════════════════════════════════════════ */
        const revealEls = document.querySelectorAll('[data-reveal]');

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('visible');
                }
            });
        }, { threshold: 0.25 });

        revealEls.forEach(el => observer.observe(el));

        /* ═══════════════════════════════════════════
           CLICK — Burst of light
           ═══════════════════════════════════════════ */
        const burstSet = ['❤️', '✨', '💛', '🌙', '✧', '💫', '🕊️', '🌷'];

        document.addEventListener('click', e => {
            for (let i = 0; i < 7; i++) {
                const el = document.createElement('span');
                el.className = 'burst';
                el.textContent = burstSet[Math.floor(Math.random() * burstSet.length)];
                el.style.left = e.clientX + 'px';
                el.style.top = e.clientY + 'px';
                el.style.setProperty('--bx', (Math.random() - 0.5) * 200 + 'px');
                el.style.setProperty('--by', (Math.random() - 0.5) * 200 + 'px');
                el.style.setProperty('--br', (Math.random() - 0.5) * 360 + 'deg');
                el.style.animationDelay = (i * 0.03) + 's';
                document.body.appendChild(el);
                setTimeout(() => el.remove(), 1000);
            }
        });
    </script>
</body>
</html>
